# =============================================================================
# ENVIRONMENT VARIABLES — ELK Stack for CloudTrail Ingestion
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env  (or: copy .env.example .env)
#   2. Fill in YOUR values below
#   3. NEVER commit .env to git (it's in .gitignore)
#
# WHERE TO FIND THESE VALUES:
#   - AWS credentials: same ones you used for "aws configure"
#     (or create new ones in AWS Console → IAM → Users → Security credentials)
#   - Bucket name: run "terraform output cloudtrail_bucket_name" from the
#     infrastructure/ folder after terraform apply
# =============================================================================

# AWS Credentials (must have s3:GetObject and s3:ListBucket on the CloudTrail bucket)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
AWS_REGION=us-east-1

# CloudTrail S3 Bucket Name
# Get this from: terraform output cloudtrail_bucket_name
# Example: cloud-detection-engineering-lab-cloudtrail-c903d763
CLOUDTRAIL_BUCKET=YOUR_CLOUDTRAIL_BUCKET_NAME_HERE
